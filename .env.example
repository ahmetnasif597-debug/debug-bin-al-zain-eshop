# ══════════════════════════════════════════════════════════════════════════════
# Bin Al-Zain — Environment Variables
# Copy this file to .env and fill in all values before running locally.
# Add ALL of these to Vercel → Project → Settings → Environment Variables.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (REQUIRED)
# Free options: https://neon.tech  or  https://supabase.com
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Admin Panel ───────────────────────────────────────────────────────────────
# bcrypt hash of the admin password (REQUIRED for production).
# Generate one with:
#   node -e "require('bcryptjs').hash('YourPassword',12).then(console.log)"
# If omitted, the plain-text ADMIN_PASSWORD is used (development only).
ADMIN_PASSWORD_HASH=$2b$12$...your_bcrypt_hash_here...

# Plain-text fallback password — only used when ADMIN_PASSWORD_HASH is not set.
# Remove this in production!
ADMIN_PASSWORD=binalzain2024

# ─── Session ───────────────────────────────────────────────────────────────────
# Long random string used to sign session cookies (REQUIRED in production).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string_in_production

# ─── Cloudinary — Image Uploads ────────────────────────────────────────────────
# Required for admin image uploads.  Free tier: 25 GB storage / 25 GB bandwidth.
# Sign up at https://cloudinary.com → Dashboard → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Redis — Session Storage ───────────────────────────────────────────────────
# Required on Vercel so sessions persist across serverless function instances.
# Free tier: https://upstash.com → Create Redis database → copy the redis:// URL
# Format: redis://default:<password>@<host>:<port>
REDIS_URL=redis://default:password@host:6379

# ─── (Local dev only — not needed on Vercel) ───────────────────────────────────
# Backend API port — Vercel ignores this; it manages ports automatically
PORT=4000
