# ─── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
# In Replit: automatically set when you provision a database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Admin Auth ────────────────────────────────────────────────────────────────
# bcrypt hash of the admin password. Generate with:
#   node -e "const b=require('bcryptjs'); b.hash('yourpassword',12).then(h=>console.log(h))"
ADMIN_PASSWORD_HASH=$2b$12$...your_bcrypt_hash_here...

# ─── Session ───────────────────────────────────────────────────────────────────
# Random secret for session encryption (optional, has a dev default)
SESSION_SECRET=change_me_in_production_to_a_long_random_string

# ─── Cloudinary (for image uploads) ───────────────────────────────────────────
# Sign up at https://cloudinary.com (free tier supports 25GB storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Redis (for session storage in production) ─────────────────────────────────
# Required on Vercel — use Upstash Redis (https://upstash.com, free tier available)
# Format: redis://default:<password>@<host>:<port>
REDIS_URL=

# ─── Ports ─────────────────────────────────────────────────────────────────────
# Backend API port (default: 4000)
PORT=4000
# Frontend dev server port (default: 3000)
# PORT=3000  (set by npm run dev in root package.json)
