{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "outDir": "../dist/api",
    "rootDir": "..",
    "noEmitOnError": false,
    "skipLibCheck": true,
    "typeRoots": [
      "../backend/node_modules/@types",
      "../node_modules/@types"
    ]
  },
  "include": [
    "**/*.ts",
    "../backend/src/**/*.ts"
  ]
}
