{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022"],
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noImplicitAny": true,
    "strictNullChecks": true
  },
  "include": ["src"]
}
