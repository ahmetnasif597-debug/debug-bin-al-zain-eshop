{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022"],
    "outDir": "dist",
    "rootDir": "src",
    "strict": false,            
    "noImplicitAny": false,     // <-- هذا التغيير هو الأهم لحل أخطاء TS7006
    "skipLibCheck": true,
    "isolatedModules": true,
    "strictNullChecks": false,  // يُفضل جعله false أيضاً لتقليل الأخطاء
    "types": ["node", "express"]
  },
  "include": ["src"]
}
